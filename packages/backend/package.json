{
  "name": "traqora-backend",
  "version": "0.1.0",
  "description": "Traqora Backend API - Stellar blockchain travel booking platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --config jest.config.cjs",
    "test:integration": "jest --config jest.config.cjs --runInBand",
    "lint": "eslint src/**/*.ts",
    "typecheck": "rimraf dist && tsc --noEmit",
    "generate:openapi": "ts-node --project tsconfig.json src/api/openapi/generator.ts",
    "verify:openapi": "ts-node --project tsconfig.json scripts/verify-openapi.ts",
    "prebuild": "npm run generate:openapi",
    "typeorm:cli": "ts-node ./node_modules/typeorm/cli.js -d src/db/dataSource.ts",
    "migration:run": "npm run typeorm:cli migration:run",
    "migration:revert": "npm run typeorm:cli migration:revert",
    "db:seed": "ts-node -r dotenv/config src/db/seeds/seeder.ts"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sendgrid/mail": "^8.1.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "@stellar/stellar-base": "^12.0.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "firebase-admin": "^13.6.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.2",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.11.5",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^5.0.3",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "soroban-client": "^1.0.0",
    "sqlite3": "^5.1.7",
    "stripe": "^16.2.0",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.12.2",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bull": "^3.15.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node-cron": "^3.0.2",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "better-sqlite3": "^12.6.2",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "rimraf": "^6.1.3",
    "sqlite3": "^5.1.7",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "zod-to-openapi": "^0.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
