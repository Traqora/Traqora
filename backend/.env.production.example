# Server Configuration
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://traqora.com

# Database
DATABASE_URL=postgres://postgres:secure-password@postgres:5432/traqora
DATABASE_ENCRYPTION_KEY=your-32-byte-encryption-key-for-database

# Redis
REDIS_URL=redis://redis:6379

# Stellar Configuration
# production, testnet, or standalone
STELLAR_NETWORK=production
HORIZON_URL=https://horizon.stellar.org
SOROBAN_RPC_URL=https://mainnet.stellar.org:443

# Contract IDs (Required in production)
BOOKING_CONTRACT_ID=
AIRLINE_CONTRACT_ID=
REFUND_CONTRACT_ID=
LOYALTY_CONTRACT_ID=
GOVERNANCE_CONTRACT_ID=
TOKEN_CONTRACT_ID=
FLIGHT_REGISTRY_CONTRACT_ID=

# Authentication
# Use a strong, unique secret for production. Should be rotated every 90 days.
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Secrets Management (Optional, recommended for production)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SECRETS_MANAGER_NAME=traqora/production/secrets

# Admin API Key
ADMIN_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=warn
AUDIT_LOG_ENABLED=true

# Refund Configuration
REFUND_IMMEDIATE_MAX=10000
REFUND_DELAY_HOURS=48
REFUND_PROCESSOR_INTERVAL=15
